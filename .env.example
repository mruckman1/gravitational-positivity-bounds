# --- Grounded Evolutionary Search: environment ---
# Copy to .env and fill in your OpenRouter key.

# OpenRouter (OpenAI-compatible). Generator + judge both route through here.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model routing (OpenRouter slugs)
QGSE_GENERATOR_MODEL=anthropic/claude-sonnet-5
QGSE_JUDGE_MODEL=google/gemini-3.5-flash

# Local Ollama embeddings for novelty archive
QGSE_EMBED_BACKEND=ollama
QGSE_EMBED_MODEL=qwen3-embedding:8b-fp16
QGSE_EMBED_DIM=4096
OLLAMA_BASE_URL=http://localhost:11434

# Optional: OpenRouter attribution headers
OPENROUTER_HTTP_REFERER=https://localhost/quantum_gravity
OPENROUTER_X_TITLE=grounded-evolutionary-search
